{"index": "079", "name": "An-Nazi'at", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "وَالنَّٰزِعَٰتِ غَرْقاٗ", "verse_2": "وَالنَّٰشِطَٰتِ نَشْطاٗ", "verse_3": "وَالسَّٰبِحَٰتِ سَبْحاٗ", "verse_4": "فَالسَّٰبِقَٰتِ سَبْقاٗ", "verse_5": "فَالْمُدَبِّرَٰتِ أَمْراٗ", "verse_6": "يَوْمَ تَرْجُفُ اُ۬لرَّاجِفَةُ", "verse_7": "تَتْبَعُهَا اَ۬لرَّادِفَةُۖ", "verse_8": "قُلُوبٞ يَوْمَئِذٖ وَاجِفَةٌ", "verse_9": "أَبْصَٰرُهَا خَٰشِعَةٞۖ", "verse_10": "يَقُولُونَ أَٰ۟نَّا لَمَرْدُودُونَ فِے اِ۬لْحَافِرَةِ", "verse_11": "إِذَا كُنَّا عِظَٰماٗ نَّخِرَةٗۖ", "verse_12": "قَالُواْ تِلْكَ إِذاٗ كَرَّةٌ خَاسِرَةٞ", "verse_13": "فَإِنَّمَا هِيَ زَجْرَةٞ وَٰحِدَةٞ", "verse_14": "فَإِذَا هُم بِالسَّاهِرَةِۖ", "verse_15": "هَلْ أَتَيٰكَ حَدِيثُ مُوسَىٰ", "verse_16": "إِذْ نَادَيٰهُ رَبُّهُۥ بِالْوَادِ اِ۬لْمُقَدَّسِ طُوَىۖ", "verse_17": "اَ۪ذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ", "verse_18": "فَقُلْ هَل لَّكَ إِلَىٰ أَن تَزَّكَّىٰ", "verse_19": "وَأَهْدِيَكَ إِلَىٰ رَبِّكَ فَتَخْشَىٰۖ", "verse_20": "فَأَرَيٰهُ اُ۬لْأٓيَةَ اَ۬لْكُبْرَىٰ", "verse_21": "فَكَذَّبَ وَعَصَىٰ", "verse_22": "ثُمَّ أَدْبَرَ يَسْعَىٰ", "verse_23": "فَحَشَرَ فَنَادَىٰ", "verse_24": "فَقَالَ أَنَا رَبُّكُمُ اُ۬لْأَعْلَىٰ", "verse_25": "فَأَخَذَهُ اُ۬للَّهُ نَكَالَ اَ۬لْأٓخِرَةِ وَالْأُولَىٰۖ", "verse_26": "إِنَّ فِے ذَٰلِكَ لَعِبْرَةٗ لِّمَنْ يَّخْشَىٰۖ", "verse_27": "ءَٰا۬نتُمْ أَشَدُّ خَلْقاً أَمِ اِ۬لسَّمَآءُۖ بَنَيٰهَا", "verse_28": "رَفَعَ سَمْكَهَا فَسَوَّيٰهَا", "verse_29": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَيٰهَاۖ", "verse_30": "وَالْأَرْضَ بَعْدَ ذَٰلِكَ دَحَيٰهَا", "verse_31": "أَخْرَجَ مِنْهَا مَآءَهَا وَمَرْعَيٰهَا", "verse_32": "وَالْجِبَالَ أَرْسَيٰهَا", "verse_33": "مَتَٰعاٗ لَّكُمْ وَلِأَنْعَٰمِكُمْۖ", "verse_34": "فَإِذَا جَآءَتِ اِ۬لطَّآمَّةُ اُ۬لْكُبْرَىٰ", "verse_35": "يَوْمَ يَتَذَكَّرُ اُ۬لْإِنسَٰنُ مَا سَعَىٰ", "verse_36": "وَبُرِّزَتِ اِ۬لْجَحِيمُ لِمَنْ يَّرَىٰۖ", "verse_37": "فَأَمَّا مَن طَغَىٰ وَءَاثَرَ اَ۬لْحَيَوٰةَ اَ۬لدُّنْيَا", "verse_38": "فَإِنَّ اَ۬لْجَحِيمَ هِيَ اَ۬لْمَأْوَىٰۖ", "verse_39": "وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى اَ۬لنَّفْسَ عَنِ اِ۬لْهَوَىٰ", "verse_40": "فَإِنَّ اَ۬لْجَنَّةَ هِيَ اَ۬لْمَأْوَىٰۖ", "verse_41": "۞ يَسْـَٔلُونَكَ عَنِ اِ۬لسَّاعَةِ أَيَّانَ مُرْسَيٰهَاۖ", "verse_42": "فِيمَ أَنتَ مِن ذِكْرَيٰهَاۖ", "verse_43": "إِلَىٰ رَبِّكَ مُنتَهَيٰهَاۖ", "verse_44": "إِنَّمَا أَنتَ مُنذِرُ مَنْ يَّخْشَيٰهَاۖ", "verse_45": "كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُواْ إِلَّا عَشِيَّةً أَوْ ضُحَيٰهَاۖ"}, "count": 45}