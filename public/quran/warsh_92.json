{"index": "092", "name": "Al-Layl", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "وَاليْلِ إِذَا يَغْش۪ىٰ", "verse_2": "وَالنَّه۪ارِ إِذَا تَجَلّ۪ىٰ", "verse_3": "وَمَا خَلَقَ اَ۬لذَّكَرَ وَالُانث۪ىٰٓ", "verse_4": "إِنَّ سَعْيَكُمْ لَشَتّ۪ىٰۖ", "verse_5": "فَأَمَّا مَنَ اَعْط۪ىٰ وَاتَّق۪ىٰ", "verse_6": "وَصَدَّقَ بِالْحُسْن۪ىٰ", "verse_7": "فَسَنُيَسِّرُهُۥ لِلْيُسْر۪ىٰۖ", "verse_8": "وَأَمَّا مَنۢ بَخِلَ وَاسْتَغْن۪ىٰ", "verse_9": "وَكَذَّبَ بِالْحُسْن۪ىٰ", "verse_10": "فَسَنُيَسِّرُهُۥ لِلْعُسْر۪ىٰۖ", "verse_11": "وَمَا يُغْنِے عَنْهُ مَالُهُۥٓ إِذَا تَرَدّ۪ىٰٓۖ", "verse_12": "إِنَّ عَلَيْنَا لَلْهُد۪ىٰ", "verse_13": "وَإِنَّ لَنَا لَلَاخِرَةَ وَالُاول۪ىٰۖ", "verse_14": "فَأَنذَرْتُكُمْ نَاراٗ تَلَظّ۪ىٰ", "verse_15": "لَا يَصْلَيٰهَآ إِلَّا اَ۬لَاشْقَي", "verse_16": "اَ۬لذِے كَذَّبَ وَتَوَلّ۪ىٰۖ", "verse_17": "وَسَيُجَنَّبُهَا اَ۬لَاتْقَي", "verse_18": "اَ۬لذِے يُوتِے مَالَهُۥ يَتَزَكّ۪ىٰۖ", "verse_19": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٖ تُجْز۪ىٰٓ", "verse_20": "إِلَّا اَ۪بْتِغَآءَ وَجْهِ رَبِّهِ اِ۬لَاعْل۪ىٰۖ", "verse_21": "وَلَسَوْفَ يَرْض۪ىٰۖ"}, "count": 21}