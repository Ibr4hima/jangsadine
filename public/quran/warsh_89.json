{"index": "089", "name": "Al-Fajr", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "وَالْفَجْرِ", "verse_2": "وَلَيَالٍ عَشْرٖ", "verse_3": "وَالشَّفْعِ وَالْوَتْرِ", "verse_4": "وَاليْلِ إِذَا يَسْرِۦ", "verse_5": "هَلْ فِے ذَٰلِكَ قَسَمٞ لِّذِے حِجْرٍۖ", "verse_6": "اَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍ", "verse_7": "اِرَمَ ذَاتِ اِ۬لْعِمَادِ", "verse_8": "اِ۬لتِے لَمْ يُخْلَقْ مِثْلُهَا فِے اِ۬لْبِلَٰدِ", "verse_9": "وَثَمُودَ اَ۬لذِينَ جَابُواْ اُ۬لصَّخْرَ بِالْوَادِۦ", "verse_10": "وَفِرْعَوْنَ ذِے اِ۬لَاوْتَادِ", "verse_11": "اِ۬لذِينَ طَغَوْاْ فِے اِ۬لْبِلَٰدِ", "verse_12": "فَأَكْثَرُواْ فِيهَا اَ۬لْفَسَادَ", "verse_13": "فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍۖ", "verse_14": "اِنَّ رَبَّكَ لَبِالْمِرْصَادِۖ", "verse_15": "فَأَمَّا اَ۬لِانسَٰنُ إِذَا مَا اَ۪بْتَل۪يٰهُ رَبُّهُۥ فَأَكْرَمَهُۥ وَنَعَّمَهُۥ", "verse_16": "فَيَقُولُ رَبِّيَ أَكْرَمَنِۦۖ", "verse_17": "وَأَمَّآ إِذَا مَا اَ۪بْتَل۪يٰهُ فَقَدَرَ عَلَيْهِ رِزْقَهُۥ", "verse_18": "فَيَقُولُ رَبِّيَ أَهَٰنَنِۦ", "verse_19": "كَلَّاۖ بَل لَّا تُكْرِمُونَ اَ۬لْيَتِيمَ", "verse_20": "وَلَا تَحُضُّونَ عَلَىٰ طَعَامِ اِ۬لْمِسْكِينِ", "verse_21": "وَتَاكُلُونَ اَ۬لتُّرَاثَ أَكْلاٗ لَّمّاٗ", "verse_22": "وَتُحِبُّونَ اَ۬لْمَالَ حُبّاٗ جَمّاٗ", "verse_23": "كَلَّآۖ إِذَا دُكَّتِ اِ۬لَارْضُ دَكّاٗ دَكّاٗ", "verse_24": "وَجَآءَ رَبُّكَ وَالْمَلَكُ صَفّاٗ صَفّاٗ", "verse_25": "وَجِےٓءَ يَوْمَئِذِۢ بِجَهَنَّمَ", "verse_26": "يَوْمَئِذٖ يَتَذَكَّرُ اُ۬لِانسَٰنُ وَأَنّ۪ىٰ لَهُ اُ۬لذِّكْر۪ىٰۖ", "verse_27": "يَقُولُ يَٰلَيْتَنِے قَدَّمْتُ لِحَيَاتِےۖ", "verse_28": "فَيَوْمَئِذٖ لَّا يُعَذِّبُ عَذَابَهُۥٓ أَحَدٞ", "verse_29": "وَلَا يُوثِقُ وَثَاقَهُۥٓ أَحَدٞۖ", "verse_30": "يَٰٓأَيَّتُهَا اَ۬لنَّفْسُ اُ۬لْمُطْمَئِنَّةُ", "verse_31": "اُ۪رْجِعِےٓ إِلَىٰ رَبِّكِ رَاضِيَةٗ مَّرْضِيَّةٗ", "verse_32": "فَادْخُلِے فِے عِبَٰدِے وَادْخُلِے جَنَّتِےۖ"}, "count": 32}