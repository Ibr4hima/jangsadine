{"index": "055", "name": "Ar-Rahman", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "اِ۬لرَّحْمَٰنُ عَلَّمَ اَ۬لْقُرْءَانَۖ", "verse_2": "خَلَقَ اَ۬لْإِنسَٰنَ عَلَّمَهُ اُ۬لْبَيَانَۖ", "verse_3": "اَ۬لشَّمْسُ وَالْقَمَرُ بِحُسْبَانٖۖ", "verse_4": "وَالنَّجْمُ وَالشَّجَرُ يَسْجُدَٰنِۖ", "verse_5": "وَالسَّمَآءَ رَفَعَهَا وَوَضَعَ اَ۬لْمِيزَانَ", "verse_6": "أَلَّا تَطْغَوْاْ فِے اِ۬لْمِيزَانِ", "verse_7": "وَأَقِيمُواْ اُ۬لْوَزْنَ بِالْقِسْطِ وَلَا تُخْسِرُواْ اُ۬لْمِيزَانَۖ", "verse_8": "وَالْأَرْضَ وَضَعَهَا لِلْأَنَامِ", "verse_9": "فِيهَا فَٰكِهَةٞ وَالنَّخْلُ ذَاتُ اُ۬لْأَكْمَامِ", "verse_10": "وَالْحَبُّ ذُو اُ۬لْعَصْفِ وَالرَّيْحَانُۖ", "verse_11": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_12": "خَلَقَ اَ۬لْإِنسَٰنَ مِن صَلْصَٰلٖ كَالْفَخَّارِ", "verse_13": "وَخَلَقَ اَ۬لْجَآنَّ مِن مَّارِجٖ مِّن نَّارٖۖ", "verse_14": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_15": "رَبُّ اُ۬لْمَشْرِقَيْنِ وَرَبُّ اُ۬لْمَغْرِبَيْنِۖ", "verse_16": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_17": "مَرَجَ اَ۬لْبَحْرَيْنِ يَلْتَقِيَٰنِ", "verse_18": "بَيْنَهُمَا بَرْزَخٞ لَّا يَبْغِيَٰنِۖ", "verse_19": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_20": "يُخْرَجُ مِنْهُمَا اَ۬للُّؤْلُؤُاْ وَالْمَرْجَانُۖ", "verse_21": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_22": "وَلَهُ اُ۬لْجَوَارِ اِ۬لْمُنشَأَٰتُ فِے اِ۬لْبَحْرِ كَالْأَعْلَٰمِۖ", "verse_23": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_24": "كُلُّ مَنْ عَلَيْهَا فَانٖ", "verse_25": "وَيَبْقَىٰ وَجْهُ رَبِّكَ ذُو اُ۬لْجَلَٰلِ وَالْإِكْرَامِۖ", "verse_26": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_27": "يَسْـَٔلُهُۥ مَن فِے اِ۬لسَّمَٰوَٰتِ وَالْأَرْضِ كُلَّ يَوْمٍ هُوَ فِے شَأْنٖۖ", "verse_28": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_29": "سَنَفْرُغُ لَكُمْ أَيُّهَ اَ۬لثَّقَلَٰنِۖ", "verse_30": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_31": "۞ يَٰمَعْشَرَ اَ۬لْجِنِّ وَالْإِنسِ إِنِ اِ۪سْتَطَعْتُمْ أَن تَنفُذُواْ مِنْ أَقْطَارِ اِ۬لسَّمَٰوَٰتِ وَالْأَرْضِ فَانفُذُواْۖ لَا تَنفُذُونَ إِلَّا بِسُلْطَٰنٖۖ", "verse_32": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_33": "يُرْسَلُ عَلَيْكُمَا شُوَاظٞ مِّن نَّارٖ", "verse_34": "وَنُحَاسٞ فَلَا تَنتَصِرَٰنِۖ", "verse_35": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_36": "فَإِذَا اَ۪نشَقَّتِ اِ۬لسَّمَآءُ فَكَانَتْ وَرْدَةٗ كَالدِّهَانِ", "verse_37": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ", "verse_38": "فَيَوْمَئِذٖ لَّا يُسْـَٔلُ عَن ذَنۢبِهِۦ إِنسٞ وَلَا جَآنّٞۖ", "verse_39": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_40": "يُعْرَفُ اُ۬لْمُجْرِمُونَ بِسِيمَٰهُمْ فَيُؤْخَذُ بِالنَّوَٰصِے وَالْأَقْدَامِۖ", "verse_41": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_42": "هَٰذِهِۦ جَهَنَّمُ اُ۬لتِے يُكَذِّبُ بِهَا اَ۬لْمُجْرِمُونَ", "verse_43": "يَطُوفُونَ بَيْنَهَا وَبَيْنَ حَمِيمٍ ءَانٖۖ", "verse_44": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_45": "وَلِمَنْ خَافَ مَقَامَ رَبِّهِۦ جَنَّتَٰنِ", "verse_46": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ", "verse_47": "ذَوَاتَا أَفْنَانٖۖ", "verse_48": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_49": "فِيهِمَا عَيْنَٰنِ تَجْرِيَٰنِۖ", "verse_50": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_51": "فِيهِمَا مِن كُلِّ فَٰكِهَةٖ زَوْجَٰنِۖ", "verse_52": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_53": "مُتَّكِـِٕينَ عَلَىٰ فُرُشِۢ بَطَآئِنُهَا مِنْ إِسْتَبْرَقٖ وَجَنَا اَ۬لْجَنَّتَيْنِ دَانٖۖ", "verse_54": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_55": "فِيهِنَّ قَٰصِرَٰتُ اُ۬لطَّرْفِ لَمْ يَطْمِثْهُنَّ إِنسٞ قَبْلَهُمْ وَلَا جَآنّٞۖ", "verse_56": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_57": "كَأَنَّهُنَّ اَ۬لْيَاقُوتُ وَالْمَرْجَانُۖ", "verse_58": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_59": "هَلْ جَزَآءُ اُ۬لْإِحْسَٰنِ إِلَّا اَ۬لْإِحْسَٰنُۖ", "verse_60": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ", "verse_61": "وَمِن دُونِهِم