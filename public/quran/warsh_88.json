{"index": "088", "name": "Al-Ghashiyah", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "هَلَ اَت۪يٰكَ حَدِيثُ اُ۬لْغَٰشِيَةِۖ", "verse_2": "وُجُوهٞ يَوْمَئِذٍ خَٰشِعَةٌ", "verse_3": "عَامِلَةٞ نَّاصِبَةٞ", "verse_4": "تَصْلَىٰ نَاراً حَامِيَةٗ", "verse_5": "تُسْق۪ىٰ مِنْ عَيْنٍ اٰنِيَةٖۖ", "verse_6": "لَّيْسَ لَهُمْ طَعَامٌ اِلَّا مِن ضَرِيعٖ", "verse_7": "لَّا يُسْمِنُ وَلَا يُغْنِے مِن جُوعٖۖ", "verse_8": "وُجُوهٞ يَوْمَئِذٖ نَّاعِمَةٞ", "verse_9": "لِّسَعْيِهَا رَاضِيَةٞ", "verse_10": "فِے جَنَّةٍ عَالِيَةٖ", "verse_11": "لَّا تُسْمَعُ فِيهَا لَٰغِيَةٞۖ", "verse_12": "فِيهَا عَيْنٞ جَارِيَةٞۖ", "verse_13": "فِيهَا سُرُرٞ مَّرْفُوعَةٞ", "verse_14": "وَأَكْوَابٞ مَّوْضُوعَةٞ", "verse_15": "وَنَمَارِقُ مَصْفُوفَةٞ", "verse_16": "وَزَرَابِيُّ مَبْثُوثَةٌۖ", "verse_17": "۞ اَفَلَا يَنظُرُونَ إِلَى اَ۬لِابِلِ كَيْفَ خُلِقَتْ", "verse_18": "وَإِلَى اَ۬لسَّمَآءِ كَيْفَ رُفِعَتْ", "verse_19": "وَإِلَى اَ۬لْجِبَالِ كَيْفَ نُصِبَتْ", "verse_20": "وَإِلَى اَ۬لَارْضِ كَيْفَ سُطِحَتْۖ", "verse_21": "فَذَكِّرِ اِنَّمَآ أَنتَ مُذَكِّرٞۖ", "verse_22": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍۖ", "verse_23": "اِلَّا مَن تَوَلّ۪ىٰ وَكَفَرَ", "verse_24": "فَيُعَذِّبُهُ اُ۬للَّهُ اُ۬لْعَذَابَ اَ۬لَاكْبَرَۖ", "verse_25": "إِنَّ إِلَيْنَآ إِيَابَهُمْ", "verse_26": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُمْۖ"}, "count": 26}