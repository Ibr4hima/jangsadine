{"index": "114", "name": "An-Nas", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "قُلْ أَعُوذُ بِرَبِّ اِ۬لنَّاسِ", "verse_2": "مَلِكِ اِ۬لنَّاسِ", "verse_3": "إِلَٰهِ اِ۬لنَّاسِ", "verse_4": "مِن شَرِّ اِ۬لْوَسْوَاسِ اِ۬لْخَنَّاسِ", "verse_5": "اِ۬لذِے يُوَسْوِسُ فِے صُدُورِ اِ۬لنَّاسِ", "verse_6": "مِنَ اَ۬لْجِنَّةِ وَالنَّاسِۖ"}, "count": 6}