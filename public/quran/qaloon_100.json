{"index": "100", "name": "Al-'Adiyat", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "وَالْعَٰدِيَٰتِ ضَبْحاٗ", "verse_2": "فَالْمُورِيَٰتِ قَدْحاٗ", "verse_3": "فَالْمُغِيرَٰتِ صُبْحاٗ", "verse_4": "فَأَثَرْنَ بِهِۦ نَقْعاٗ", "verse_5": "فَوَسَطْنَ بِهِۦ جَمْعاً", "verse_6": "إِنَّ اَ۬لْإِنسَٰنَ لِرَبِّهِۦ لَكَنُودٞ", "verse_7": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٞ", "verse_8": "وَإِنَّهُۥ لِحُبِّ اِ۬لْخَيْرِ لَشَدِيدٌۖ", "verse_9": "۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِے اِ۬لْقُبُورِ", "verse_10": "وَحُصِّلَ مَا فِے اِ۬لصُّدُورِ", "verse_11": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٖ لَّخَبِيرُۢۖ"}, "count": 11}