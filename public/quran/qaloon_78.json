{"index": "078", "name": "An-Naba", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "عَمَّۖ يَتَسَآءَلُونَ", "verse_2": "عَنِ اِ۬لنَّبَإِ اِ۬لْعَظِيمِ", "verse_3": "اِ۬لذِے هُمْ فِيهِ مُخْتَلِفُونَۖ", "verse_4": "كَلَّا سَيَعْلَمُونَ", "verse_5": "ثُمَّ كَلَّا سَيَعْلَمُونَۖ", "verse_6": "أَلَمْ نَجْعَلِ اِ۬لْأَرْضَ مِهَٰداٗ", "verse_7": "وَالْجِبَالَ أَوْتَاداٗ", "verse_8": "وَخَلَقْنَٰكُمْ أَزْوَٰجاٗ", "verse_9": "وَجَعَلْنَا نَوْمَكُمْ سُبَاتاٗ", "verse_10": "وَجَعَلْنَا اَ۬ليْلَ لِبَاساٗ", "verse_11": "وَجَعَلْنَا اَ۬لنَّهَارَ مَعَاشاٗ", "verse_12": "وَبَنَيْنَا فَوْقَكُمْ سَبْعاٗ شِدَاداٗ", "verse_13": "وَجَعَلْنَا سِرَاجاٗ وَهَّاجاٗ", "verse_14": "وَأَنزَلْنَا مِنَ اَ۬لْمُعْصِرَٰتِ مَآءٗ ثَجَّاجاٗ", "verse_15": "لِّنُخْرِجَ بِهِۦ حَبّاٗ وَنَبَاتاٗ", "verse_16": "وَجَنَّٰتٍ أَلْفَافاًۖ", "verse_17": "إِنَّ يَوْمَ اَ۬لْفَصْلِ كَانَ مِيقَٰتاٗ", "verse_18": "يَوْمَ يُنفَخُ فِے اِ۬لصُّورِ فَتَأْتُونَ أَفْوَاجاٗ", "verse_19": "وَفُتِّحَتِ اِ۬لسَّمَآءُ فَكَانَتْ أَبْوَاباٗ", "verse_20": "وَسُيِّرَتِ اِ۬لْجِبَالُ فَكَانَتْ سَرَاباًۖ", "verse_21": "إِنَّ جَهَنَّمَ كَانَتْ مِرْصَاداٗ", "verse_22": "لِّلطَّٰغِينَ مَـَٔاباٗ", "verse_23": "لَّٰبِثِينَ فِيهَا أَحْقَاباٗۖ", "verse_24": "لَّا يَذُوقُونَ فِيهَا بَرْداٗ وَلَا شَرَاباً", "verse_25": "إِلَّا حَمِيماٗ وَغَسَاقاٗ", "verse_26": "جَزَآءٗ وِفَاقاًۖ", "verse_27": "إِنَّهُمْ كَانُواْ لَا يَرْجُونَ حِسَاباٗ", "verse_28": "وَكَذَّبُواْ بِـَٔايَٰتِنَا كِذَّاباٗۖ", "verse_29": "وَكُلَّ شَےْءٍ أَحْصَيْنَٰهُ كِتَٰباٗۖ", "verse_30": "فَذُوقُواْ فَلَن نَّزِيدَكُمْ إِلَّا عَذَاباًۖ", "verse_31": "إِنَّ لِلْمُتَّقِينَ مَفَازاً", "verse_32": "حَدَآئِقَ وَأَعْنَٰباٗ", "verse_33": "وَكَوَاعِبَ أَتْرَاباٗ", "verse_34": "وَكَأْساٗ دِهَاقاٗ", "verse_35": "لَّا يَسْمَعُونَ فِيهَا لَغْواٗ وَلَا كِذَّاباٗۖ", "verse_36": "جَزَآءٗ مِّن رَّبِّكَ عَطَآءً حِسَاباٗۖ", "verse_37": "رَّبُّ اُ۬لسَّمَٰوَٰتِ وَالْأَرْضِ وَمَا بَيْنَهُمَاۖ اَ۬لرَّحْمَٰنُ لَا يَمْلِكُونَ مِنْهُ خِطَاباٗۖ", "verse_38": "يَوْمَ يَقُومُ اُ۬لرُّوحُ وَالْمَلَٰٓئِكَةُ صَفّاٗ لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ اُ۬لرَّحْمَٰنُ وَقَالَ صَوَاباٗۖ", "verse_39": "ذَٰلِكَ اَ۬لْيَوْمُ اُ۬لْحَقُّۖ فَمَن شَآءَ اَ۪تَّخَذَ إِلَىٰ رَبِّهِۦ مَـَٔاباًۖ", "verse_40": "إِنَّا أَنذَرْنَٰكُمْ عَذَاباٗ قَرِيباٗ يَوْمَ يَنظُرُ اُ۬لْمَرْءُ مَا قَدَّمَتْ يَدَٰهُ وَيَقُولُ اُ۬لْكَافِرُ يَٰلَيْتَنِے كُنتُ تُرَٰباَۢۖ"}, "count": 40}