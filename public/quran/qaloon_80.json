{"index": "080", "name": "Abasa", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "عَبَسَ وَتَوَلَّىٰ", "verse_2": "أَن جَآءَهُ اُ۬لْأَعْمَىٰۖ", "verse_3": "وَمَا يُدْرِيكَۖ لَعَلَّهُۥ يَزَّكَّىٰ", "verse_4": "أَوْ يَذَّكَّرُ فَتَنفَعُهُ اُ۬لذِّكْرَىٰۖ", "verse_5": "أَمَّا مَنِ اِ۪سْتَغْنَىٰ", "verse_6": "فَأَنتَ لَهُۥ تَصَّدَّىٰ", "verse_7": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰۖ", "verse_8": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ", "verse_9": "وَهْوَ يَخْشَىٰ", "verse_10": "فَأَنتَ عَنْهُ تَلَهَّىٰ", "verse_11": "كَلَّاۖ إِنَّهَا تَذْكِرَةٞۖ", "verse_12": "فَمَن شَآءَ ذَكَرَهُۥ", "verse_13": "فِے صُحُفٖ مُّكَرَّمَةٖ", "verse_14": "مَّرْفُوعَةٖ مُّطَهَّرَةِۢ", "verse_15": "بِأَيْدِے سَفَرَةٖ", "verse_16": "كِرَامِۢ بَرَرَةٖۖ", "verse_17": "قُتِلَ اَ۬لْإِنسَٰنُ مَا أَكْفَرَهُۥۖ", "verse_18": "مِنْ أَيِّ شَےْءٍ خَلَقَهُۥۖ", "verse_19": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ", "verse_20": "ثُمَّ اَ۬لسَّبِيلَ يَسَّرَهُۥ", "verse_21": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥۖ", "verse_22": "ثُمَّ إِذَا شَا أَنشَرَهُۥۖ", "verse_23": "كَلَّا لَمَّا يَقْضِ مَا أَمَرَهُۥۖ", "verse_24": "فَلْيَنظُرِ اِ۬لْإِنسَٰنُ إِلَىٰ طَعَامِهِۦۖ", "verse_25": "إِنَّا صَبَبْنَا اَ۬لْمَآءَ صَبّاٗ", "verse_26": "ثُمَّ شَقَقْنَا اَ۬لْأَرْضَ شَقّاٗ", "verse_27": "فَأَنۢبَتْنَا فِيهَا حَبّاٗ", "verse_28": "وَعِنَباٗ وَقَضْباٗ", "verse_29": "وَزَيْتُوناٗ وَنَخْلاٗ", "verse_30": "وَحَدَآئِقَ غُلْباٗ", "verse_31": "وَفَٰكِهَةٗ وَأَبّاٗ", "verse_32": "مَّتَٰعاٗ لَّكُمْ وَلِأَنْعَٰمِكُمْۖ", "verse_33": "فَإِذَا جَآءَتِ اِ۬لصَّآخَّةُ", "verse_34": "يَوْمَ يَفِرُّ اُ۬لْمَرْءُ مِنْ أَخِيهِ", "verse_35": "وَأُمِّهِۦ وَأَبِيهِ", "verse_36": "وَصَٰحِبَتِهِۦ وَبَنِيهِۖ", "verse_37": "لِكُلِّ اِ۪مْرِےٕٖ مِّنْهُمْ يَوْمَئِذٖ شَأْنٞ يُغْنِيهِۖ", "verse_38": "وُجُوهٞ يَوْمَئِذٖ مُّسْفِرَةٞ", "verse_39": "ضَاحِكَةٞ مُّسْتَبْشِرَةٞۖ", "verse_40": "وَوُجُوهٞ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٞ", "verse_41": "تَرْهَقُهَا قَتَرَةٌۖ", "verse_42": "أُوْلَٰٓئِكَ هُمُ اُ۬لْكَفَرَةُ اُ۬لْفَجَرَةُۖ"}, "count": 42}