{"index": "075", "name": "Al-Qiyamah", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "لَا أُقْسِمُ بِيَوْمِ اِ۬لْقِيَٰمَةِ", "verse_2": "وَلَا أُقْسِمُ بِالنَّفْسِ اِ۬للَّوَّامَةِۖ", "verse_3": "أَيَحْسِبُ اُ۬لْإِنسَٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ", "verse_4": "بَلَىٰۖ قَٰدِرِينَ عَلَىٰ أَن نُّسَوِّيَ بَنَانَهُۥۖ", "verse_5": "بَلْ يُرِيدُ اُ۬لْإِنسَٰنُ لِيَفْجُرَ أَمَامَهُۥۖ", "verse_6": "يَسْـَٔلُ أَيَّانَ يَوْمُ اُ۬لْقِيَٰمَةِۖ", "verse_7": "فَإِذَا بَرَقَ اَ۬لْبَصَرُ", "verse_8": "وَخَسَفَ اَ۬لْقَمَرُ", "verse_9": "وَجُمِعَ اَ۬لشَّمْسُ وَالْقَمَرُ", "verse_10": "يَقُولُ اُ۬لْإِنسَٰنُ يَوْمَئِذٍ أَيْنَ اَ۬لْمَفَرُّۖ", "verse_11": "كَلَّا لَا وَزَرَۖ", "verse_12": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ اِ۬لْمُسْتَقَرُّۖ", "verse_13": "يُنَبَّؤُاْ اُ۬لْإِنسَٰنُ يَوْمَئِذِۢ بِمَا قَدَّمَ وَأَخَّرَۖ", "verse_14": "بَلِ اِ۬لْإِنسَٰنُ عَلَىٰ نَفْسِهِۦ بَصِيرَةٞ", "verse_15": "وَلَوْ أَلْقَىٰ مَعَاذِيرَهُۥۖ", "verse_16": "لَا تُحَرِّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦۖ إِنَّ عَلَيْنَا جَمْعَهُۥ وَقُرْءَانَهُۥۖ", "verse_17": "فَإِذَا قَرَأْنَٰهُ فَاتَّبِعْ قُرْءَانَهُۥ", "verse_18": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥۖ", "verse_19": "كَلَّا بَلْ تُحِبُّونَ اَ۬لْعَاجِلَةَ", "verse_20": "وَتَذَرُونَ اَ۬لْأٓخِرَةَۖ", "verse_21": "وُجُوهٞ يَوْمَئِذٖ نَّاضِرَةٌ", "verse_22": "إِلَىٰ رَبِّهَا نَاظِرَةٞۖ", "verse_23": "وَوُجُوهٞ يَوْمَئِذِۢ بَاسِرَةٞ", "verse_24": "تَظُنُّ أَنْ يُّفْعَلَ بِهَا فَاقِرَةٞۖ", "verse_25": "كَلَّا إِذَا بَلَغَتِ اِ۬لتَّرَاقِيَ", "verse_26": "وَقِيلَ مَن رَّاقٖ", "verse_27": "وَظَنَّ أَنَّهُ اُ۬لْفِرَاقُ", "verse_28": "وَالْتَفَّتِ اِ۬لسَّاقُ بِالسَّاقِ", "verse_29": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ اِ۬لْمَسَاقُۖ", "verse_30": "فَلَا صَدَّقَ وَلَا صَلَّىٰۖ", "verse_31": "وَلَٰكِن كَذَّبَ وَتَوَلَّىٰۖ", "verse_32": "ثُمَّ ذَهَبَ إِلَىٰ أَهْلِهِۦ يَتَمَطَّىٰۖ", "verse_33": "أَوْلَىٰ لَكَ فَأَوْلَىٰ", "verse_34": "ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰۖ", "verse_35": "أَيَحْسِبُ اُ۬لْإِنسَٰنُ أَنْ يُّتْرَكَ سُدىًۖ", "verse_36": "أَلَمْ يَكُ نُطْفَةٗ مِّن مَّنِيّٖ تُمْنَىٰ", "verse_37": "ثُمَّ كَانَ عَلَقَةٗ فَخَلَقَ فَسَوَّىٰ", "verse_38": "فَجَعَلَ مِنْهُ اُ۬لزَّوْجَيْنِ اِ۬لذَّكَرَ وَالْأُنثَىٰۖ", "verse_39": "أَلَيْسَ ذَٰلِكَ بِقَٰدِرٍ عَلَىٰ أَنْ يُّحْـِۧيَ اَ۬لْمَوْتَىٰۖ"}, "count": 39}