{"index": "096", "name": "Al-'Alaq", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "اَ۪قْرَأْ بِاسْمِ رَبِّكَ اَ۬لذِے خَلَقَۖ", "verse_2": "خَلَقَ اَ۬لِانسَٰنَ مِنْ عَلَقٍۖ", "verse_3": "اِ۪قْرَأْ وَرَبُّكَ اَ۬لَاكْرَمُ", "verse_4": "اُ۬لذِے عَلَّمَ بِالْقَلَمِ", "verse_5": "عَلَّمَ اَ۬لِانسَٰنَ مَا لَمْ يَعْلَمْۖ", "verse_6": "كَلَّآ إِنَّ اَ۬لِانسَٰنَ لَيَطْغ۪ىٰٓ", "verse_7": "أَن رّ۪ء۪اهُ اُ۪سْتَغْن۪ىٰٓۖ", "verse_8": "إِنَّ إِلَىٰ رَبِّكَ اَ۬لرُّجْع۪ىٰٓۖ", "verse_9": "أَرَٰٓيْتَ اَ۬لذِے يَنْه۪ىٰ", "verse_10": "عَبْداً اِذَا صَلّ۪ىٰٓۖ", "verse_11": "أَرَٰٓيْتَ إِن كَانَ عَلَى اَ۬لْهُد۪ىٰٓ", "verse_12": "أَوَ اَمَرَ بِالتَّقْو۪ىٰٓۖ", "verse_13": "أَرَٰٓيْتَ إِن كَذَّبَ وَتَوَلّ۪ىٰٓ", "verse_14": "أَلَمْ يَعْلَم بِأَنَّ اَ۬للَّهَ يَر۪ىٰۖ", "verse_15": "كَلَّا لَئِن لَّمْ يَنتَهِ", "verse_16": "لَنَسْفَعاَۢ بِالنَّاصِيَةِ", "verse_17": "نَاصِيَةٖ كَٰذِبَةٍ خَاطِئَةٖۖ", "verse_18": "فَلْيَدْعُ نَادِيَهُۥ", "verse_19": "سَنَدْعُ اُ۬لزَّبَانِيَةَۖ", "verse_20": "كَلَّا لَا تُطِعْهُ وَاسْجُدْ وَاقْتَرِبِۖ۩"}, "count": 20}