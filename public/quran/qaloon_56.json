{"index": "056", "name": "Al-Waqi'ah", "verse": {"verse_0": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ", "verse_1": "إِذَا وَقَعَتِ اِ۬لْوَاقِعَةُ", "verse_2": "لَيْسَ لِوَقْعَتِهَا كَٰذِبَةٌۖ", "verse_3": "خَافِضَةٞ رَّافِعَةٌ", "verse_4": "إِذَا رُجَّتِ اِ۬لْأَرْضُ رَجّاٗ", "verse_5": "وَبُسَّتِ اِ۬لْجِبَالُ بَسّاٗ", "verse_6": "فَكَانَتْ هَبَآءٗ مُّنۢبَثّاٗ", "verse_7": "وَكُنتُمْ أَزْوَٰجاٗ ثَلَٰثَةٗۖ", "verse_8": "فَأَصْحَٰبُ اُ۬لْمَيْمَنَةِ", "verse_9": "مَا أَصْحَٰبُ اُ۬لْمَيْمَنَةِۖ", "verse_10": "وَأَصْحَٰبُ اُ۬لْمَشْـَٔمَةِ", "verse_11": "مَا أَصْحَٰبُ اُ۬لْمَشْـَٔمَةِۖ", "verse_12": "وَالسَّٰبِقُونَ اَ۬لسَّٰبِقُونَۖ", "verse_13": "أُوْلَٰٓئِكَ اَ۬لْمُقَرَّبُونَ", "verse_14": "فِے جَنَّٰتِ اِ۬لنَّعِيمِۖ", "verse_15": "ثُلَّةٞ مِّنَ اَ۬لْأَوَّلِينَ", "verse_16": "وَقَلِيلٞ مِّنَ اَ۬لْأٓخِرِينَ", "verse_17": "عَلَىٰ سُرُرٖ مَّوْضُونَةٖ", "verse_18": "مُّتَّكِـِٕينَ عَلَيْهَا مُتَقَٰبِلِينَۖ", "verse_19": "يَطُوفُ عَلَيْهِمْ وِلْدَٰنٞ مُّخَلَّدُونَ", "verse_20": "بِأَكْوَابٖ وَأَبَارِيقَ", "verse_21": "وَكَأْسٖ مِّن مَّعِينٖ", "verse_22": "لَّا يُصَدَّعُونَ عَنْهَا وَلَا يُنزَفُونَ", "verse_23": "وَفَٰكِهَةٖ مِّمَّا يَتَخَيَّرُونَ", "verse_24": "وَلَحْمِ طَيْرٖ مِّمَّا يَشْتَهُونَۖ", "verse_25": "وَحُورٌ عِينٞ كَأَمْثَٰلِ اِ۬للُّؤْلُوِٕ اِ۬لْمَكْنُونِ", "verse_26": "جَزَآءَۢ بِمَا كَانُواْ يَعْمَلُونَۖ", "verse_27": "لَا يَسْمَعُونَ فِيهَا لَغْواٗ وَلَا تَأْثِيماًۖ", "verse_28": "إِلَّا قِيلاٗ سَلَٰماٗ سَلَٰماٗۖ", "verse_29": "۞ وَأَصْحَٰبُ اُ۬لْيَمِينِ مَا أَصْحَٰبُ اُ۬لْيَمِينِۖ", "verse_30": "فِے سِدْرٖ مَّخْضُودٖ", "verse_31": "وَطَلْحٖ مَّنضُودٖ", "verse_32": "وَظِلّٖ مَّمْدُودٖ", "verse_33": "وَمَآءٖ مَّسْكُوبٖ", "verse_34": "وَفَٰكِهَةٖ كَثِيرَةٖ", "verse_35": "لَّا مَقْطُوعَةٖ وَلَا مَمْنُوعَةٖ", "verse_36": "وَفُرُشٖ مَّرْفُوعَةٍۖ", "verse_37": "إِنَّا أَنشَأْنَٰهُنَّ إِنشَآءٗ", "verse_38": "فَجَعَلْنَٰهُنَّ أَبْكَاراً", "verse_39": "عُرُباً أَتْرَاباٗ", "verse_40": "لِّأَصْحَٰبِ اِ۬لْيَمِينِۖ", "verse_41": "ثُلَّةٞ مِّنَ اَ۬لْأَوَّلِينَ", "verse_42": "وَثُلَّةٞ مِّنَ اَ۬لْأٓخِرِينَۖ", "verse_43": "وَأَصْحَٰبُ اُ۬لشِّمَالِ", "verse_44": "مَا أَصْحَٰبُ اُ۬لشِّمَالِۖ", "verse_45": "فِے سَمُومٖ وَحَمِيمٖ", "verse_46": "وَظِلّٖ مِّنْ يَّحْمُومٖ", "verse_47": "لَّا بَارِدٖ وَلَا كَرِيمٍۖ", "verse_48": "إِنَّهُمْ كَانُواْ قَبْلَ ذَٰلِكَ مُتْرَفِينَۖ", "verse_49": "وَكَانُواْ يُصِرُّونَ عَلَى اَ۬لْحِنثِ اِ۬لْعَظِيمِۖ", "verse_50": "وَكَانُواْ يَقُولُونَ أَٰئِذَا مِتْنَا وَكُنَّا تُرَاباٗ وَعِظَٰماً إِنَّا لَمَبْعُوثُونَ", "verse_51": "أَوْءَابَآؤُنَا اَ۬لْأَوَّلُونَۖ", "verse_52": "قُلْ إِنَّ اَ۬لْأَوَّلِينَ وَالْأٓخِرِينَ لَمَجْمُوعُونَ", "verse_53": "إِلَىٰ مِيقَٰتِ يَوْمٖ مَّعْلُومٖۖ", "verse_54": "ثُمَّ إِنَّكُمْ أَيُّهَا اَ۬لضَّآلُّونَ اَ۬لْمُكَذِّبُونَ", "verse_55": "لَأٓكِلُونَ مِن شَجَرٖ مِّن زَقُّومٖ", "verse_56": "فَمَالِـُٔونَ مِنْهَا اَ۬لْبُطُونَ", "verse_57": "فَشَٰرِبُونَ عَلَيْهِ مِنَ اَ۬لْحَمِيمِ", "verse_58": "فَشَٰرِبُونَ شُرْبَ اَ۬لْهِيمِۖ", "verse_59": "هَٰذَا نُزُلُهُمْ يَوْمَ اَ۬لدِّينِۖ", "verse_60": "نَحْنُ خَلَقْنَٰكُمْۖ فَلَوْلَا تُصَدِّقُونَۖ", "verse_61": "أَفَرَٰ۬يْتُم مَّا تُمْنُونَ", "verse_62": "ءَٰا۬نتُمْ تَخْلُقُونَهُۥ أَمْ نَحْنُ اُ۬لْخَٰلِقُونَۖ", "verse_63": "نَحْنُ قَدَّرْنَا بَيْنَكُمُ اُ۬لْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ", "verse_64": "عَلَىٰ أَن نُّبَدِّلَ أَمْثَٰلَكُمْ وَنُنشِئَكُمْ فِے مَا لَا تَعْلَمُونَۖ", "verse_65": "وَلَقَدْ عَلِمْتُمُ اُ۬لنَّشْأَةَ اَ۬لْأُولَىٰۖ فَلَوْلَا تَذَّكَّرُونَۖ", "verse_66": "أَفَرَٰ۬يْتُم مَّا تَحْرُثُونَ", "verse_67": "ءَٰا۬نتُمْ تَزْرَعُونَهُۥ أَمْ نَحْنُ اُ۬لزَّٰرِعُونَۖ", "verse_68": "لَوْ نَشَآءُ لَجَعَلْنَٰهُ حُطَٰماٗ فَظَلْتُمْ تَفَكَّهُونَ", "verse_69": "إِنَّا لَمُغْرَمُونَ", "verse_70": "بَلْ نَحْنُ مَحْرُومُونَۖ", "verse_71": "أَفَرَٰ۬يْتُمُ اُ۬لْمَآءَ اَ۬لذِے تَشْرَبُونَ", "verse_72": "ءَٰا۬نتُمْ أَنزَلْتُمُوهُ مِنَ اَ۬لْمُزْنِ أَمْ نَحْنُ اُ۬لْمُنزِلُونَۖ", "verse_73": "لَوْ نَشَآءُ جَعَلْنَٰهُ أُجَاجاٗۖ فَلَوْلَا تَشْكُرُونَۖ", "verse_74": "أَفَرَٰ۬يْتُمُ اُ۬لنَّارَ اَ۬لتِے تُورُونَ", "verse_75": "ءَٰا۬نتُمْ أَنشَأْتُمْ شَجَرَتَهَا أَمْ نَحْنُ اُ۬لْمُنشِـُٔونَۖ", "verse_76": "نَحْنُ جَعَلْنَٰهَا تَذْكِرَةٗ وَمَتَٰعاٗ لِّلْمُقْوِينَۖ", "verse_77": "فَسَبِّحْ بِاسْمِ رَبِّكَ اَ۬لْعَظِيمِۖ", "verse_78": "۞ فَلَا أُقْسِمُ بِمَوَٰقِعِ اِ۬لنُّجُومِ", "verse_79": "وَإِنَّهُۥ لَقَسَمٞ لَّوْ تَعْلَمُونَ عَظِيمٌ", "verse_80": "إِنَّهُۥ لَقُرْءَانٞ كَرِيمٞ", "verse_81": "فِے كِتَٰبٖ مَّكْنُونٖ", "verse_82": "لَّا يَمَسُّهُۥ إِلَّا اَ۬لْمُطَهَّرُونَۖ", "verse_83": "تَنزِيلٞ مِّن رَّبِّ اِ۬لْعَٰلَمِينَۖ", "verse_84": "أَفَبِهَٰذَا اَ۬لْحَدِيثِ أَنتُم مُّدْهِنُونَ", "verse_85": "وَتَجْعَلُونَ رِزْقَكُمْ أَنَّكُمْ تُكَذِّبُونَۖ", "verse_86": "فَلَوْلَا إِذَا بَلَغَتِ اِ۬لْحُلْقُومَ", "verse_87": "وَأَنتُمْ حِينَئِذٖ تَنظُرُونَ", "verse_88": "وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنكُمْ وَلَٰكِن لَّا تُبْصِرُونَ", "verse_89": "فَلَوْلَا إِن كُنتُمْ غَيْرَ مَدِينِينَ", "verse_90": "تَرْجِعُونَهَا إِن كُنتُمْ صَٰدِقِينَۖ", "verse_91": "فَأَمَّا إِن كَانَ مِنَ اَ۬لْمُقَرَّبِينَ", "verse_92": "فَرَوْحٞ وَرَيْحَانٞ وَجَنَّتُ نَعِيمٖۖ", "verse_93": "وَأَمَّا إِن كَانَ مِنْ أَصْحَٰبِ اِ۬لْيَمِينِ", "verse_94": "فَسَلَٰمٞ لَّكَ مِنْ أَصْحَٰبِ اِ۬لْيَمِينِۖ", "verse_95": "وَأَمَّا إِن كَانَ مِنَ اَ۬لْمُكَذِّبِينَ اَ۬لضَّآلِّينَ", "verse_96": "فَنُزُلٞ مِّنْ حَمِيمٖ", "verse_97": "وَتَصْلِيَةُ جَحِيمٍۖ", "verse_98": "إِنَّ هَٰذَا لَهْوَ حَقُّ اُ۬لْيَقِينِۖ", "verse_99": "فَسَبِّحْ بِاسْمِ رَبِّكَ اَ۬لْعَظِيمِۖ"}, "count": 99}